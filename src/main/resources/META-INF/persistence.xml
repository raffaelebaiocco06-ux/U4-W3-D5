<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="2.2"
             xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
    <persistence-unit name="u4-w3-d5">
      <!--classi-->
        <class>raffaele.entities.Catalogo</class>
        <class>raffaele.entities.Prestito</class>
        <class>raffaele.entities.Utente</class>
        <class>raffaele.entities.Libro</class>
        <class>raffaele.entities.Rivista</class>

        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/u4-w3-d5"/>

            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="1234"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <!-- Quest'ultima impostazione servirà per far creare/aggiornare automaticamente le tabelle all'avvio dell'applicazione -->
        </properties>
    </persistence-unit>
</persistence>